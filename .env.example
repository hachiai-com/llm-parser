# Database Configuration
# DATABASE_URL=jdbc:mysql://localhost:3306/test
LLM_PARSER_DATABASE_TYPE=mysql
LLM_PARSER_DATABASE_HOST=localhost # USER HOST NAME
LLM_PARSER_DATABASE_PORT=3306 # USER PORT NAME
LLM_PARSER_DATABASE_USERNAME=root # USER USER NAME 
LLM_PARSER_DATABASE_PASSWORD= # LEAVE '' IF NO PASSWORD ELSE PASSWORD
LLM_PARSER_DATABASE_NAME=test # USER DATABASE NAME

# LLM API Configuration
LLM_PARSER_HACHIAI_LLM_TOKEN=20EbiWCq234aslkTESTrQVBJ5kYjR6ACMeSm #UPDATE THIS
LLM_PARSER_HACHIAI_LLM_TYPE=llm
LLM_PARSER_HACHIAI_LLM_MAX_TOKEN=8096
LLM_PARSER_HACHIAI_LLM_TEMPERATURE=0.00
LLM_PARSER_HACHIAI_LLM_HTTP_TIMEOUT=200
LLM_PARSER_HACHIAI_LLM_ENABLE_VALIDATION=false
LLM_PARSER_HACHIAI_LLM_ENABLE_CONFIDENCE_SCORE=true

# LLM API Endpoints
LLM_PARSER_HACHIAI_LLM_API=https://docx-proxy.hachiai.com/slm/v1/llm/qna/async
LLM_PARSER_HACHIAI_LLM_STATUS_API_URL=https://docx-proxy.hachiai.com/slm/v1/trace_id/
LLM_PARSER_HACHIAI_LLM_CONVERSATION_API=https://docx-proxy.hachiai.com/slm/v1/llm/qna/conversations/async

# LLM Status Polling
LLM_PARSER_HACHIAI_LLM_STATUS_API_TOTAL_ITERATIONS=1
LLM_PARSER_HACHIAI_LLM_STATUS_API_INTERVAL_MINUTES=3
LLM_PARSER_HACHIAI_LLM_CONVERSATION_API_TOTAL_ITERATIONS=3
LLM_PARSER_HACHIAI_LLM_CONVERSATION_API_INTERVAL_SECONDS=20

# Dynamic Parser Query
LLM_PARSER_HACHIAI_LLM_DYNAMIC_PARSER_QUERY=As an expert in Optical Character Recognition (OCR) and invoice template identification, your task is to analyze the provided invoice image and accurately extract key details exclusively from the first page and the first table. For each of the following queries, deliver a precise and concise answer:\r\n\r\n1. **Company Name:**\r\n\r\n   - Extract the primary company name from the first line of text or from the company logo.\r\n   - Omit any taglines, slogans, or additional descriptive text that may appear in subsequent lines.\r\n   - If the name spans multiple lines, use only the first line.\r\n   - If the company name is not found, return \"Not Found\" for this field.\r\n\r\n2. **Company Website:**\r\n\r\n   - Extract the website address, including any prefixes such as \"www.\", \"http://\", or \"https://\".\r\n   - If no website is present, return \"Not Found\" for this field.\r\n\r\n3. **First Column Name:**\r\n\r\n   - Identify and return the name of the first column from the first items table on the invoice.\r\n   - If no table is present, return \"Not Found\" for this field.\r\n\r\n**Output Format:**\r\n\r\nReturn the results in a single JSON object with the following keys: \"Company Name\", \"Company Website\" and \"First Column Name\". For example:\r\njson\r\n{\r\n  \"company_name\": \"Example\",\r\n  \"company_website\": \"www.example.com\",\r\n  \"first_column_mame\": \"Price\"\r\n}\r\n\r\n\r\nIf a value is unavailable for any field, the corresponding key should have the value \"Not Found\". Ensure that all extraction is performed using only the information on the first page and the first table, and maintain consistent extraction methods based on positional and structural cues across similar templates.

